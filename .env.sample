# BC-Bench Environment Variables
# Copy this file to .env and fill in your values

# Azure DevOps Personal Access Token (required for reading NAV PRs, Work Items and connecting to bc-eval package)
ADO_TOKEN=your_ado_token_here

# BC Container
BC_CONTAINER_NAME=bcbench
BC_CONTAINER_USERNAME=admin
BC_CONTAINER_PASSWORD=your_container_password_here

# Optional: Set to "1" to enable debug logging in GitHub Actions
# RUNNER_DEBUG=1

# bcal agent (required for 'bcbench run bcal' / 'bcbench evaluate bcal')
AZURE_OPENAI_ENDPOINT=your_azure_openai_endpoint_here
AZURE_OPENAI_DEPLOYMENT=gpt-5.2

# Optional: switch the BC-Bench bcal agent backend. 'azure-openai' (default) or 'capi' (CopilotService).
# BCAL_AI_PROVIDER=capi
# BCAL_AI_MODEL=gpt-5  # CAPI model alias

# CAPI / CopilotService configuration (used when BCAL_AI_PROVIDER=capi)
# CAPI_ENDPOINT=https://capi-api.wus-il002.gateway.test.island.powerapps.com
# CAPI_SCOPE=api://4309f23c-178a-4fc7-a36e-68d8fee6ca7b/.default
# CAPI_ORG_GUID=8f6f3b1e-8c4d-4e2e-9f3a-123456789abc
# CAPI_TENANT_ID=72f988bf-86f1-41af-91ab-2d7cd011db47
# CAPI_USER_OBJECT_ID=12345678-90ab-cdef-1234-567890abcdef
# CAPI_PARTNER_SOURCE=BusinessCentral.Microsoft.Interactive

# CAPI cert-based auth. Set all three to enable.
# CAPI_CLIENT_ID=5a362b5f-1301-4412-8dda-146c4475b37b
# CAPI_CERTIFICATE_KEY_VAULT_NAME=LocalDeployment-keyvault
# CAPI_CERTIFICATE_NAME=DataPlaneLocalDeploymentServices
